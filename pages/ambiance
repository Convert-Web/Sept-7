<script>
// LOADER
const loader=document.getElementById('loader');document.body.style.overflow='hidden';setTimeout(()=>{loader.classList.add('hidden');document.body.style.overflow='';},2200);
// NAVBAR
const navbar=document.getElementById('navbar');window.addEventListener('scroll',()=>navbar.classList.toggle('scrolled',window.scrollY>40),{passive:true});
// BURGER
const burger=document.getElementById('burger'),mobileNav=document.getElementById('mobile-nav');
burger.addEventListener('click',()=>{burger.classList.toggle('open');mobileNav.classList.toggle('open');document.body.style.overflow=mobileNav.classList.contains('open')?'hidden':'';});
mobileNav.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{burger.classList.remove('open');mobileNav.classList.remove('open');document.body.style.overflow='';}));
// REVEAL
const revObs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');revObs.unobserve(e.target);}});},{threshold:.1,rootMargin:'0px 0px -60px 0px'});
document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));
// TIMELINE REVEAL
const tlObs=new IntersectionObserver(entries=>{entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*120);tlObs.unobserve(e.target);}});},{threshold:.2});
document.querySelectorAll('.tl-item').forEach(el=>tlObs.observe(el));
// PARTICLES
const pc=document.getElementById('particles');
if(pc){
  const colors=['#8b2bff','#a855f7','#ff4136','#f0a500','#fff'];
  const n=window.innerWidth>768?28:12;
  for(let i=0;i<n;i++){
    const p=document.createElement('div');p.className='particle';
    const sz=Math.random()*4+2,col=colors[Math.floor(Math.random()*colors.length)];
    p.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;background:${col};box-shadow:0 0 ${sz*3}px ${col};--drift:${(Math.random()-.5)*120}px;animation-duration:${Math.random()*8+6}s;animation-delay:-${Math.random()*8}s;`;
    pc.appendChild(p);
  }
}
// MOOD PLAYER
const bars=document.querySelectorAll('.mood-bar');
const playBtn=document.getElementById('mood-play');
let playing=false,ivs=[];
const startBars=()=>{bars.forEach(b=>{ivs.push(setInterval(()=>b.style.height=(Math.random()*90+10)+'%',120));});};
const stopBars=()=>{ivs.forEach(clearInterval);ivs=[];bars.forEach(b=>b.style.height='30%');};
playBtn?.addEventListener('click',()=>{playing=!playing;playBtn.textContent=playing?'⏸':'▶';playing?startBars():stopBars();});
// ANIMATIONS
@keyframes fadeInDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
</script>
<style>
@keyframes fadeInDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
</style>
