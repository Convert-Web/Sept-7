<style>
:root{--black:#06060a;--black-2:#0d0d14;--black-3:#141420;--violet:#8b2bff;--vglow:#a855f7;--vdim:#4c1d95;--red:#c0392b;--rglow:#ff4136;--gold:#f0a500;--gsoft:#fbbf24;--white:#f2f0eb;--wdim:#a09e99;--glass:rgba(255,255,255,.04);--gborder:rgba(255,255,255,.08);--tr:.35s cubic-bezier(.4,0,.2,1);--r:6px;--rl:16px;--fd:"Bebas Neue",sans-serif;--fb:"Rajdhani",sans-serif;--fa:"Barlow Condensed",sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{background:var(--black);color:var(--white);font-family:var(--fb);font-weight:500;overflow-x:hidden;-webkit-font-smoothing:antialiased}a{color:inherit;text-decoration:none}img{display:block;max-width:100%}ul{list-style:none}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--black-2)}::-webkit-scrollbar-thumb{background:var(--vdim);border-radius:2px}

/* LOADER */
#loader{position:fixed;inset:0;background:var(--black);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;transition:opacity .6s,visibility .6s}#loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
.ld-logo{font-family:var(--fd);font-size:clamp(48px,10vw,90px);letter-spacing:.08em;color:var(--white);text-shadow:0 0 40px var(--violet),0 0 80px var(--vglow);animation:pulseGlow 1.5s ease-in-out infinite alternate}
.ld-bar{width:200px;height:2px;background:var(--gborder);border-radius:2px;overflow:hidden}.ld-prog{height:100%;background:linear-gradient(90deg,var(--violet),var(--rglow));width:0;border-radius:2px;animation:loadBar 2s ease forwards}.ld-tag{font-family:var(--fa);font-size:11px;letter-spacing:.3em;color:var(--wdim);text-transform:uppercase}
@keyframes loadBar{to{width:100%}}@keyframes pulseGlow{from{text-shadow:0 0 30px var(--violet)}to{text-shadow:0 0 60px var(--violet),0 0 120px var(--vglow),0 0 180px var(--red)}}

/* NAVBAR */
.navbar{position:fixed;top:0;left:0;right:0;z-index:1000;padding:20px 40px;display:flex;align-items:center;justify-content:space-between;transition:var(--tr)}
.navbar.scrolled{background:rgba(6,6,10,.88);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);padding:14px 40px;border-bottom:1px solid var(--gborder)}
.nav-logo{font-family:var(--fd);font-size:28px;letter-spacing:.05em;text-shadow:0 0 20px var(--violet)}.nav-logo span{color:var(--vglow)}
.nav-links{display:flex;align-items:center;gap:36px}.nav-links a{font-family:var(--fa);font-size:13px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--wdim);transition:var(--tr);position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--violet),var(--rglow));transition:width var(--tr)}
.nav-links a:hover{color:var(--white)}.nav-links a:hover::after,.nav-links a.active::after{width:100%}.nav-links a.active{color:var(--white)}
.nav-cta{background:linear-gradient(135deg,var(--violet),var(--red))!important;color:var(--white)!important;padding:10px 22px;border-radius:var(--r);box-shadow:0 4px 20px rgba(139,43,255,.4)}.nav-cta::after{display:none!important}
.nav-burger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;z-index:1001}.nav-burger span{display:block;width:24px;height:2px;background:var(--white);transition:var(--tr)}
.nav-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}.nav-burger.open span:nth-child(2){opacity:0}.nav-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.nav-mobile{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--black-2);z-index:998;padding:100px 40px 40px;flex-direction:column;gap:28px;transform:translateX(100%);transition:transform .4s cubic-bezier(.4,0,.2,1);display:flex}.nav-mobile.open{transform:translateX(0)}.nav-mobile a{font-family:var(--fd);font-size:48px;letter-spacing:.04em;color:var(--wdim)}.nav-mobile a:hover{color:var(--vglow)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 32px;font-family:var(--fa);font-size:13px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;border-radius:var(--r);border:none;cursor:pointer;transition:var(--tr);text-decoration:none}
.btn-primary{background:linear-gradient(135deg,var(--violet),var(--red));color:var(--white);box-shadow:0 6px 30px rgba(139,43,255,.35)}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 40px rgba(139,43,255,.55)}
.btn-outline{background:transparent;color:var(--white);border:1px solid var(--gborder)}.btn-outline:hover{background:var(--glass);border-color:var(--vglow);color:var(--vglow)}
.btn-wa{background:#25D366;color:#fff;box-shadow:0 6px 24px rgba(37,211,102,.35)}.btn-wa:hover{transform:translateY(-2px);box-shadow:0 10px 36px rgba(37,211,102,.55)}

/* REVEAL */
.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s cubic-bezier(.4,0,.2,1),transform .8s cubic-bezier(.4,0,.2,1)}.reveal.visible{opacity:1;transform:translateY(0)}.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}.d5{transition-delay:.5s}

/* MISC */
.sec-label{font-family:var(--fa);font-size:11px;font-weight:700;letter-spacing:.4em;text-transform:uppercase;color:var(--vglow);margin-bottom:16px;display:block}
.sec-title{font-family:var(--fd);font-size:clamp(40px,6vw,72px);line-height:.95;letter-spacing:.02em;color:var(--white);margin-bottom:20px}
.sec-sub{font-size:16px;line-height:1.7;color:var(--wdim);max-width:500px}

/* CINEMATIC INTRO */
.amb-intro{min-height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.amb-bg{position:absolute;inset:0;background:linear-gradient(135deg,#06060a 0%,#0d0020 40%,#200010 70%,#060606 100%)}
.amb-bg::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 600px 600px at 30% 50%,rgba(139,43,255,.3) 0%,transparent 65%),radial-gradient(ellipse 500px 500px at 70% 50%,rgba(192,57,43,.25) 0%,transparent 65%),radial-gradient(ellipse 300px 300px at 50% 80%,rgba(240,165,0,.1) 0%,transparent 60%);animation:ambGlow 6s ease-in-out infinite alternate}
@keyframes ambGlow{0%{transform:scale(1)}100%{transform:scale(1.1)}}

/* City SVG */
.city-sil{position:absolute;bottom:0;left:0;right:0;height:40%;pointer-events:none;z-index:1}
.city-sil svg{width:100%;height:100%}

/* Particles */
.particles{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}
.particle{position:absolute;border-radius:50%;animation:floatPart linear infinite;opacity:0}
@keyframes floatPart{0%{transform:translateY(100vh) translateX(0);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateY(-20px) translateX(var(--drift));opacity:0}}

.amb-content{position:relative;z-index:3;text-align:center;max-width:800px;padding:120px 24px}
.amb-big-title{font-family:var(--fd);font-size:clamp(48px,12vw,140px);line-height:.85;letter-spacing:.03em;margin-bottom:24px}
.t1{display:block;color:var(--white)}.t2{display:block;-webkit-text-stroke:2px var(--vglow);color:transparent;filter:drop-shadow(0 0 20px var(--vglow))}.t3{display:block;color:var(--gsoft);filter:drop-shadow(0 0 16px var(--gold))}

/* VIBES GRID */
.vibes-sec{padding:80px 40px;background:var(--black-2)}
.vibes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;max-width:1200px;margin:48px auto 0}
.vibe-card{position:relative;padding:48px 32px;background:var(--black);overflow:hidden;transition:var(--tr)}
.vibe-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--cc),transparent);opacity:.6}
.vibe-card:hover{background:var(--black-3);transform:translateY(-3px)}.vibe-card:hover::before{opacity:1}
.vibe-glow{position:absolute;bottom:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:var(--cc);opacity:.06;filter:blur(40px);transition:opacity .4s}.vibe-card:hover .vibe-glow{opacity:.14}
.vibe-emoji{font-size:44px;margin-bottom:20px}
.vibe-title{font-family:var(--fd);font-size:28px;letter-spacing:.04em;color:var(--white);margin-bottom:12px}
.vibe-text{font-size:15px;line-height:1.7;color:var(--wdim)}

/* PARALLAX BANNER */
.parallax-banner{position:relative;overflow:hidden;height:300px;display:flex;align-items:center;justify-content:center}
.pb-img{position:absolute;inset:0}.pb-img img{width:100%;height:140%;object-fit:cover;margin-top:-20%}
.pb-overlay{position:absolute;inset:0;background:linear-gradient(180deg,var(--black) 0%,rgba(6,6,10,.5) 30%,rgba(6,6,10,.5) 70%,var(--black) 100%)}
.pb-content{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;text-align:center;padding:0 24px}

/* TIMELINE */
.timeline-sec{padding:100px 40px}
.timeline{max-width:680px;margin:56px auto 0;position:relative}
.timeline::before{content:'';position:absolute;left:20px;top:0;bottom:0;width:1px;background:linear-gradient(180deg,var(--violet),var(--red),transparent)}
.tl-item{padding:0 0 48px 60px;position:relative;opacity:0;transform:translateX(-30px);transition:opacity .6s,transform .6s}
.tl-item.visible{opacity:1;transform:translateX(0)}
.tl-dot{position:absolute;left:12px;top:4px;width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,var(--violet),var(--red));box-shadow:0 0 16px var(--vglow)}
.tl-time{font-family:var(--fa);font-size:11px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--vglow);margin-bottom:8px}
.tl-title{font-family:var(--fd);font-size:28px;letter-spacing:.03em;color:var(--white);margin-bottom:8px}
.tl-text{font-size:15px;color:var(--wdim);line-height:1.7}

/* MOOD PLAYER */
.mood-sec{padding:80px 40px;background:var(--black-2);text-align:center}
.mood-player{max-width:480px;margin:48px auto 0;background:var(--black);border:1px solid var(--gborder);border-radius:20px;padding:32px;position:relative;overflow:hidden}
.mood-player::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(139,43,255,.12),transparent 70%)}
.mood-vis{display:flex;gap:3px;align-items:flex-end;justify-content:center;height:60px;margin-bottom:24px;position:relative;z-index:1}
.mood-bar{width:4px;background:linear-gradient(180deg,var(--vglow),var(--red));border-radius:2px;height:30%;transition:height .15s ease}
.mood-title{font-family:var(--fd);font-size:24px;letter-spacing:.04em;position:relative;z-index:1}
.mood-genre{font-family:var(--fa);font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--vglow);margin-top:4px;position:relative;z-index:1}
.mood-play{width:52px;height:52px;border-radius:50%;margin:24px auto 0;background:linear-gradient(135deg,var(--violet),var(--red));border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;transition:var(--tr);box-shadow:0 6px 24px rgba(139,43,255,.4);position:relative;z-index:1}.mood-play:hover{transform:scale(1.1);box-shadow:0 10px 36px rgba(139,43,255,.6)}

/* PHOTO GRID */
.photo-grid-sec{padding:80px 40px;background:var(--black)}
.photo-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;max-width:1200px;margin:40px auto 0}
.pg-item{border-radius:var(--rl);overflow:hidden;border:1px solid var(--gborder)}
.pg-item img{width:100%;height:100%;object-fit:cover;transition:transform .6s}.pg-item:hover img{transform:scale(1.06)}
.pg-item.big{grid-column:span 2;grid-row:span 2;aspect-ratio:1}
.pg-item.sm{aspect-ratio:1}

/* CTA FINAL */
.amb-cta{padding:100px 40px;text-align:center;background:var(--black-2);position:relative;overflow:hidden}
.amb-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(139,43,255,.12),transparent);pointer-events:none}

/* FOOTER */
footer{background:var(--black-2);border-top:1px solid var(--gborder);padding:60px 40px 30px}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:48px;max-width:1200px;margin:0 auto 48px}
.footer-logo{font-family:var(--fd);font-size:40px;letter-spacing:.05em;text-shadow:0 0 20px var(--violet);margin-bottom:16px}.footer-logo span{color:var(--vglow)}
.footer-brand p{color:var(--wdim);font-size:14px;line-height:1.7;margin-bottom:24px}.footer-socials{display:flex;gap:12px}
.soc-icon{width:40px;height:40px;background:var(--glass);border:1px solid var(--gborder);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;transition:var(--tr)}.soc-icon:hover{border-color:var(--vglow);background:rgba(139,43,255,.15);transform:translateY(-2px)}
.footer-col h4{font-family:var(--fa);font-size:11px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--vglow);margin-bottom:20px}.footer-col ul{display:flex;flex-direction:column;gap:10px}.footer-col ul li a{font-size:14px;color:var(--wdim);transition:var(--tr)}.footer-col ul li a:hover{color:var(--white);padding-left:6px}
.footer-bot{display:flex;align-items:center;justify-content:space-between;padding-top:24px;border-top:1px solid var(--gborder);max-width:1200px;margin:0 auto}.footer-bot p{font-size:12px;color:var(--wdim)}

/* RESPONSIVE */
@media(max-width:900px){.vibes-grid{grid-template-columns:1fr}.vibes-sec{padding:60px 24px}.timeline-sec{padding:70px 24px}.mood-sec{padding:60px 24px}.photo-grid-sec{padding:60px 24px}.amb-cta{padding:70px 24px}.navbar{padding:16px 24px}.nav-links{display:none}.nav-burger{display:flex}.photo-grid{grid-template-columns:1fr 1fr}.pg-item.big{grid-column:span 2}.footer-grid{grid-template-columns:1fr 1fr;gap:32px}}
@media(max-width:500px){.photo-grid{grid-template-columns:1fr 1fr}.amb-big-title{font-size:clamp(48px,16vw,80px)}.footer-grid{grid-template-columns:1fr}.footer-bot{flex-direction:column;gap:8px;text-align:center}}
</style>
</head>
